{
  "name": "@go-fish/frontend",
  "version": "0.1.0",
  "exports": "./src/main.ts",
  "compilerOptions": {
    "lib": ["ESNext", "DOM"]
  },
  "tasks": {
    "dev": "deno run -A --node-modules-dir=auto npm:vite"
  },
  "imports": {
    "assert": "node:assert",
    "buffer": "node:buffer",
    "process": "node:process",
    "crypto": "node:crypto",
    "stream": "node:stream",
    "util": "node:util",
    "tls": "node:tls",
    "net": "node:net",
    "fs": "node:fs",
    "path": "node:path",
    "os": "node:os",
    "events": "node:events",
    "http": "node:http",
    "https": "node:https",
    "url": "node:url",
    "querystring": "node:querystring",
    "zlib": "node:zlib",
    "module": "node:module",
    "child_process": "node:child_process",
    "tty": "node:tty",
    "dns": "node:dns",
    "v8": "node:v8",
    "worker_threads": "node:worker_threads",
    "string_decoder": "node:string_decoder",
    "perf_hooks": "node:perf_hooks",
    "@midnight-ntwrk/compact-runtime": "npm:@midnight-ntwrk/compact-runtime@0.14.0",
    "@midnight-ntwrk/onchain-runtime-v2": "npm:@midnight-ntwrk/onchain-runtime-v2@2.0.0",
    "@midnight-ntwrk/ledger-v7": "npm:@midnight-ntwrk/ledger-v7@7.0.0"
  },
  "nodeModulesDir": "auto"
}
